@model HMS.Models.BillingViewVm

@{
    ViewData["Title"] = "View Bill Queue";
    var hasBill = Model.Billing != null;
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1">Bill Queue</h4>
            <div class="text-muted">Case Sheet: @Model.CaseSheetId</div>
            @if (Model.Patient != null)
            {
                <div class="fw-semibold mt-1">@Model.Patient.PatientName</div>
            }
        </div>
        @if (hasBill)
        {
            <div class="text-end">
                <div class="badge bg-success">Bill Generated</div>
                <div class="fw-semibold mt-2">@Model.Billing!.BillNo</div>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Pending Services</h5>
        @if (!hasBill && Model.PendingItems.Any())
        {
            <form asp-action="CreateBill" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="caseSheetId" value="@Model.CaseSheetId" />
                <button type="submit" class="btn btn-primary">Generate Bill</button>
            </form>
        }
    </div>
    <div class="card-body">
        @if (Model.PendingItems.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Service</th>
                            <th>Rate</th>
                            <th>Qty</th>
                            <th>Discount %</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PendingItems)
                        {
                            <tr>
                                <td>@item.ServiceName</td>
                                <td>@item.Rate.ToString("0.00")</td>
                                <td>@item.Quantity</td>
                                <td>@item.DiscountPer.ToString("0.00")</td>
                                <td>@item.Amount.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-end fw-semibold">
                Total: @Model.PendingItems.Sum(x => x.Amount).ToString("0.00")
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">
                No pending services found for this case sheet.
            </div>
        }
    </div>
</div>
