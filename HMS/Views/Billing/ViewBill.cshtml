@model HMS.Models.BillingViewVm

@{
    ViewData["Title"] = "Bill Details";
    var bill = Model.Billing;
}

@if (bill == null)
{
    <div class="alert alert-warning">Bill not found.</div>
    <a class="btn btn-outline-secondary" asp-action="PaidBills">Back</a>
    return;
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1">@bill.BillNo</h4>
            <div class="text-muted">Case Sheet: @bill.CaseSheetId</div>
            <div class="text-muted">Bill Date: @bill.BillDate.ToString("dd-MMM-yyyy HH:mm")</div>
            @if (Model.Patient != null)
            {
                <div class="fw-semibold mt-1">@Model.Patient.PatientName</div>
                <div class="text-muted">@Model.Patient.OpNo</div>
            }
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" onclick="window.print()">Print</button>
            @if (!bill.IsCancelled)
            {
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelBillModal">Cancel Bill</button>
            }
            <a class="btn btn-outline-primary" asp-action="PaidBills">Paid Bills</a>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-white">
        <h5 class="mb-0">Services</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Service</th>
                        <th>Quantity</th>
                        <th>Rate</th>
                        <th>Discount</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.BillingDetails)
                    {
                        <tr>
                            <td>@(item.Service?.ServiceName ?? string.Empty)</td>
                            <td>@item.Quantity</td>
                            <td>@item.Rate.ToString("0.00")</td>
                            <td>@item.DiscountPer.ToString("0.00")</td>
                            <td>@item.Amount.ToString("0.00")</td>
                            <td>
                                @if (item.IsCancelled)
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!item.IsCancelled && !bill.IsCancelled)
                                {
                                    <form asp-action="CancelService" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="BillId" value="@bill.BillId" />
                                        <input type="hidden" name="BillDetailId" value="@item.BillDetailId" />
                                        <input type="hidden" name="CancelReason" value="Service cancelled" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Cancel Service</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row justify-content-end">
            <div class="col-md-4">
                <div class="d-flex justify-content-between">
                    <span>Gross Total</span>
                    <strong>@bill.GrossAmount.ToString("0.00")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Discount</span>
                    <strong>@bill.DiscountAmount.ToString("0.00")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Net Amount</span>
                    <strong>@bill.NetAmount.ToString("0.00")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Paid</span>
                    <strong>@bill.PaidAmount.ToString("0.00")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Refund</span>
                    <strong>@bill.RefundAmount.ToString("0.00")</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h5 class="mb-0">Payments</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Mode</th>
                        <th>Amount</th>
                        <th>Refund</th>
                        <th>Transaction No</th>
                        <th>Date</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td>@payment.PaymentMode</td>
                            <td>@payment.Amount.ToString("0.00")</td>
                            <td>@payment.RefundAmount.ToString("0.00")</td>
                            <td>@payment.TransactionNo</td>
                            <td>@payment.PaymentDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td>@payment.Remarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelBillModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CancelBill" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BillId" value="@bill.BillId" />
                <div class="modal-header">
                    <h5 class="modal-title">Cancel Bill</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason</label>
                    <textarea name="CancelReason" class="form-control" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-danger">Cancel Bill</button>
                </div>
            </form>
        </div>
    </div>
</div>
