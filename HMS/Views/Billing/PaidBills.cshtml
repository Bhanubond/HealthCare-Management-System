@model IEnumerable<HMS.Models.BillingListItemVm>

@{
    ViewData["Title"] = "Paid Bills";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0">Paid Bills</h4>
            <small class="text-muted">Completed bill records.</small>
        </div>
        <a class="btn btn-outline-primary" asp-action="Index">Unpaid Bills</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end mb-3">
            <div class="col-md-2">
                <label class="form-label">Department</label>
                <input name="department" value="@ViewBag.Department" class="form-control" type="number" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Patient</label>
                <input name="patient" value="@ViewBag.Patient" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Bill No</label>
                <input name="billNo" value="@ViewBag.BillNo" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Bill Date</label>
                <input name="billDate" value="@ViewBag.BillDate" class="form-control" type="date" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a class="btn btn-outline-secondary" asp-action="PaidBills">Clear</a>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>OP/IP No</th>
                        <th>Bill No</th>
                        <th>Case Sheet</th>
                        <th>Net Amount</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Bill Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bill in Model)
                    {
                        <tr>
                            <td>@bill.PatientName</td>
                            <td>@bill.OpNo</td>
                            <td>@bill.BillNo</td>
                            <td>@bill.CaseSheetId</td>
                            <td>@bill.NetAmount.ToString("0.00")</td>
                            <td>@bill.PaidAmount.ToString("0.00")</td>
                            <td>@bill.BalanceAmount.ToString("0.00")</td>
                            <td>@bill.BillDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="ViewBill" asp-route-id="@bill.BillId">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
