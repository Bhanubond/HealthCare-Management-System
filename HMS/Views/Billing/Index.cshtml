@model IEnumerable<HMS.Models.BillingListItemVm>

@{
    ViewData["Title"] = "Pending Billing";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0">Pending Billing</h4>
            <small class="text-muted">Unprocessed department services waiting for payment.</small>
        </div>
        <a class="btn btn-outline-primary" asp-action="PaidBills">Paid Bills</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>OP/IP No</th>
                        <th>Case Sheet</th>
                        <th>Department</th>
                        <th>Pending Services</th>
                        <th>Total Amount</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var bill in Model)
                        {
                            <tr>
                                <td>@bill.PatientName</td>
                                <td>@bill.OpNo</td>
                                <td>@bill.CaseSheetId</td>
                                <td>@bill.DeptName</td>
                                <td>@bill.PendingServiceCount</td>
                                <td>@bill.NetAmount.ToString("0.00")</td>
                                <td>@bill.BillDate.ToString("dd-MMM-yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-primary"
                                       asp-action="View"
                                       asp-route-patientId="@bill.PatientId"
                                       asp-route-caseSheetId="@bill.CaseSheetId"
                                       asp-route-deptId="@bill.DeptId">View</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No pending services found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
