@model IEnumerable<HMS.Models.BillingListItemVm>

@{
    ViewData["Title"] = "Unpaid Bills";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0">Unpaid Bills</h4>
            <small class="text-muted">Bills that still have a balance due.</small>
        </div>
        <a class="btn btn-outline-primary" asp-action="PaidBills">Paid Bills</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Bill No</th>
                        <th>Case Sheet</th>
                        <th>Net Amount</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Bill Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bill in Model)
                    {
                        <tr>
                            <td>@bill.PatientName</td>
                            <td>@bill.BillNo</td>
                            <td>@bill.CaseSheetId</td>
                            <td>@bill.NetAmount.ToString("0.00")</td>
                            <td>@bill.PaidAmount.ToString("0.00")</td>
                            <td>@bill.BalanceAmount.ToString("0.00")</td>
                            <td>@bill.BillDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-primary" asp-action="View" asp-route-id="@bill.BillQueueId">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
