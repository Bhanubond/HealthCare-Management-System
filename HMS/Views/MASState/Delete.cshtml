@model HMS.Entities.MASState

@{
    ViewData["Title"] = "Delete State";
}

<div class="card shadow-sm border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0 fw-bold">Delete State</h4>
    </div>

    <div class="card-body">
        <div class="alert alert-warning">
            Are you sure you want to delete this record?
        </div>

        <div class="row g-3">
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">State ID</div><div class="col-sm-8">@Model.StateId</div></div></div>
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">State Name</div><div class="col-sm-8">@Model.StateName</div></div></div>
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">Country</div><div class="col-sm-8">@Model.Country?.CountryName</div></div></div>
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">Status</div><div class="col-sm-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">@(Model.IsActive ? "Active" : "Inactive")</span></div></div></div>
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">Deleted</div><div class="col-sm-8">@(Model.IsDeleted ? "Yes" : "No")</div></div></div>
            <div class="col-md-6"><div class="row"><div class="col-sm-4 fw-bold">Default</div><div class="col-sm-8">@(Model.IsDefault ? "Yes" : "No")</div></div></div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
            <input type="hidden" asp-for="StateId" />
            <button type="submit" class="btn btn-danger fw-bold">Delete</button>
            <a asp-action="Index" class="btn btn-secondary fw-bold">Cancel</a>
        </form>
    </div>
</div>
