@model List<HMS.Models.DashboardScreenCardViewModel>

<div class="screen-card-strip">
    @if (Model.Count == 0)
    {
        <div class="empty-state w-100">
            <div class="empty-state__icon">
                <i class="bi bi-grid"></i>
            </div>
            <h5 class="mb-1">No screens mapped</h5>
            <p class="text-muted mb-0">This department has no active screens configured yet.</p>
        </div>
    }
    else
    {
        @foreach (var screen in Model)
        {
            <a asp-controller="@screen.ControllerName"
               asp-action="@screen.ActionName"
               class="screen-card @(screen.IsSelected ? "active" : "")">
                <div class="screen-card__body">
                    <div class="screen-card__title">@screen.ScreenDisplayName</div>
                </div>
            </a>
        }
    }
</div>
