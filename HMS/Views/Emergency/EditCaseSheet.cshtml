@model HMS.Models.EMRCasesheetScreenVm

@{
    var vm = Model ?? new HMS.Models.EMRCasesheetScreenVm();
}

<div class="container-fluid py-3">

    <!-- PATIENT HEADER (EMR STYLE) -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                <div>
                    <h4 class="fw-bold mb-1">🩺 Edit Case Sheet</h4>
                    <div class="text-muted small">OP No: @vm.OpNo</div>
                </div>

                <div class="d-flex gap-2 flex-wrap">

                    <span class="badge bg-light text-dark border px-3 py-2">👤 @vm.PatientName</span>
                    <span class="badge bg-light text-dark border px-3 py-2">🎂 @vm.Age yrs</span>
                    <span class="badge bg-light text-dark border px-3 py-2">⚧ @vm.Gender</span>
                    <span class="badge bg-light text-dark border px-3 py-2">👨‍⚕️ @vm.DoctorName</span>
                    <span class="badge bg-light text-dark border px-3 py-2">🎓 @vm.StudentName</span>

                </div>

            </div>

        </div>
    </div>

    <form asp-action="EditCaseSheet" method="post">

        <input type="hidden" asp-for="EMRId" />
        <input type="hidden" asp-for="PatientId" />
        <input type="hidden" asp-for="DoctorId" />
        <input type="hidden" asp-for="StudentId" />
        <input type="hidden" asp-for="AllotId" />
        <input type="hidden" asp-for="ReferredId" />
        <input type="hidden" asp-for="OpNo" />

        <!-- MODERN NAV TABS -->
        <div class="card shadow-sm border-0">

            <div class="card-header bg-white border-bottom p-0">

                <ul class="nav nav-pills nav-fill p-2 gap-2">

                    <li class="nav-item">
                        <button class="nav-link active rounded-pill" data-bs-toggle="tab" data-bs-target="#arrival" type="button"> 🚑 Arrival & Triage </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#history" type="button"> 📋 History </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#vitals" type="button"> ❤️ Vitals </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#exam" type="button">  🔍 Examination </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#treatment" type="button"> 💉 Treatment </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link rounded-pill" data-bs-toggle="tab"  data-bs-target="#disposition"  type="button"> 🏥 Disposition </button>
                    </li>

                    <li class="nav-item">
                        <button type="button" class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#medication"> 💊 Medication </button>
                    </li>

                    <li class="nav-item">
                        <button type="button" class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#appointment">  📅 Appointment </button>
                    </li>

                    <li class="nav-item">
                        <button type="button" class="nav-link rounded-pill" data-bs-toggle="tab" data-bs-target="#referrals"> 🔁 Referrals </button>
                    </li>

                </ul>

            </div>

            <div class="card-body bg-light">

                <div class="tab-content">

                    <!-- ARRIVAL -->
                    <div class="tab-pane fade show active" id="arrival">

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="fw-bold">Arrival Mode</label>
                               @*  <input class="form-control" asp-for="ArrivalMode" /> *@
                                <select asp-for="ArrivalMode" class="form-select">
                                    <option value="">Select</option>
                                    <option>Walk-in</option>
                                    <option>Ambulance</option>
                                    <option>Referral</option>
                                    <option>Police</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="fw-bold">Arrival Time</label>
                                <input class="form-control" asp-for="ArrivalTime" type="datetime-local" />
                            </div>

                            <div class="col-md-4">
                                <label class="fw-bold">Brought By</label>
                                <input class="form-control" asp-for="BroughtBy" />
                            </div>

                            <div class="col-md-4">
                                <label class="fw-bold">Triage Category</label>
                                <input class="form-control" asp-for="TriageCategory" />
                            </div>

                            <div class="col-md-4">
                                <label class="fw-bold">Triage Time</label>
                                <input class="form-control" asp-for="TriageTime" type="datetime-local" />
                            </div>

                            <div class="col-md-12">
                                <label class="fw-bold">Triage Notes</label>
                                <textarea class="form-control" asp-for="TriageNotes" rows="3"></textarea>
                            </div>

                        </div>

                    </div>


                    <!-- HISTORY -->
                    <div class="tab-pane fade" id="history">

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="fw-bold">Chief Complaint</label>
                                <textarea class="form-control" asp-for="ChiefComplaint"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">History Of Present Illness</label>
                                <textarea class="form-control" asp-for="HistoryOfPresentIllness"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Past Medical History</label>
                                <textarea class="form-control" asp-for="PastMedicalHistory"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Past Surgical History</label>
                                <textarea class="form-control" asp-for="PastSurgicalHistory"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Family History</label>
                                <textarea class="form-control" asp-for="FamilyHistory"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Personal History</label>
                                <textarea class="form-control" asp-for="PersonalHistory"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Drug History</label>
                                <textarea class="form-control" asp-for="DrugHistory"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="fw-bold">Allergy History</label>
                                <textarea class="form-control" asp-for="AllergyHistory"></textarea>
                            </div>

                        </div>

                    </div>


                    <!-- VITALS -->
                    <div class="tab-pane fade" id="vitals">

                        <div class="row g-3">

                            <div class="col-md-2">
                                <label>BP</label>
                                <input class="form-control" asp-for="BloodPressure" />
                            </div>

                            <div class="col-md-2">
                                <label>Pulse</label>
                                <input class="form-control" asp-for="PulseRate" />
                            </div>

                            <div class="col-md-2">
                                <label>Temperature</label>
                                <input class="form-control" asp-for="Temperature" />
                            </div>

                            <div class="col-md-2">
                                <label>Respiratory Rate</label>
                                <input class="form-control" asp-for="RespiratoryRate" />
                            </div>

                            <div class="col-md-2">
                                <label>SpO₂</label>
                                <input class="form-control" asp-for="SpO2" />
                            </div>

                            <div class="col-md-2">
                                <label>Weight</label>
                                <input class="form-control" asp-for="Weight" />
                            </div>

                            <div class="col-md-2">
                                <label>Height</label>
                                <input class="form-control" asp-for="Height" />
                            </div>

                            <div class="col-md-2">
                                <label>BMI</label>
                                <input class="form-control" asp-for="BMI" />
                            </div>

                            <div class="col-md-2">
                                <label>GRBS</label>
                                <input class="form-control" asp-for="GRBS" />
                            </div>

                            <div class="col-md-2">
                                <label>Pain Score</label>
                                <input class="form-control" asp-for="PainScore" />
                            </div>

                            <div class="col-md-2">
                                <label>GCS</label>
                                <input class="form-control" asp-for="GCSScore" />
                            </div>

                            <div class="col-md-12">
                                <label>Pupils</label>
                                <textarea class="form-control" asp-for="Pupils"></textarea>
                            </div>

                        </div>

                    </div>


                    <!-- EXAMINATION -->
                    <div class="tab-pane fade" id="exam">

                        <div class="row g-3">

                            @foreach (var field in new[] {
                                                        "GeneralExamination",
                                                        "CVSExamination",
                                                        "RSExamination",
                                                        "AbdomenExamination",
                                                        "CNSExamination",
                                                        "LocalExamination"
                                                        })
                            {
                            }

                            <div class="col-md-6">
                                <label>General Examination</label>
                                <textarea class="form-control" asp-for="GeneralExamination"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>CVS Examination</label>
                                <textarea class="form-control" asp-for="CVSExamination"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>RS Examination</label>
                                <textarea class="form-control" asp-for="RSExamination"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>Abdomen Examination</label>
                                <textarea class="form-control" asp-for="AbdomenExamination"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>CNS Examination</label>
                                <textarea class="form-control" asp-for="CNSExamination"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>Local Examination</label>
                                <textarea class="form-control" asp-for="LocalExamination"></textarea>
                            </div>

                        </div>

                    </div>

                    <!-- Treatment Tab -->
                    <div class="tab-pane fade" id="treatment">

                        <div class="card border-0 shadow-sm">
                            <div class="card-body">

                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label>Provisional Diagnosis</label>
                                        <textarea id="ProvisionalDiagnosis"
                                                  name="ProvisionalDiagnosis"
                                                  class="form-control">@Model.ProvisionalDiagnosis</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Investigations Ordered</label>
                                        <textarea id="InvestigationsOrdered"
                                                  name="InvestigationsOrdered"
                                                  class="form-control">@Model.InvestigationsOrdered</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Investigation Results</label>
                                        <textarea id="InvestigationResults"
                                                  name="InvestigationResults"
                                                  class="form-control">@Model.InvestigationResults</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Procedures Performed</label>
                                        <textarea id="ProceduresPerformed"
                                                  name="ProceduresPerformed"
                                                  class="form-control">@Model.ProceduresPerformed</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Emergency Treatment</label>
                                        <textarea id="EmergencyTreatment"
                                                  name="EmergencyTreatment"
                                                  class="form-control">@Model.EmergencyTreatment</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Medications Administered</label>
                                        <textarea id="MedicationsAdministered"
                                                  name="MedicationsAdministered"
                                                  class="form-control">@Model.MedicationsAdministered</textarea>
                                    </div>

                                    <div class="col-md-12">
                                        <label>IV Fluids</label>
                                        <textarea id="IVFluids"
                                                  name="IVFluids"
                                                  class="form-control">@Model.IVFluids</textarea>
                                    </div>

                                </div>

                            </div>
                        </div>

                    </div>

                    <!-- Disposition Tab -->
                    <div class="tab-pane fade" id="disposition">

                        <div class="card border-0 shadow-sm">
                            <div class="card-body">

                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label>Final Diagnosis</label>
                                        <textarea id="FinalDiagnosis"
                                                  name="FinalDiagnosis"
                                                  class="form-control">@Model.FinalDiagnosis</textarea>
                                    </div>

                                    <div class="col-md-6">
                                        <label>Disposition</label>

                                                            <select asp-for="Disposition" class="form-select">
                                                                <option value="">Select</option>
                                                                <option value="Discharge">Discharge</option>
                                                                <option value="Admission">Admission</option>
                                                                <option value="ICU">ICU</option>
                                                                <option value="Operation Theatre">Operation Theatre</option>
                                                                <option value="Referral">Referral</option>
                                                                <option value="Death">Death</option>
                                                            </select>

                                    </div>

                                    <div class="col-md-6">
                                        <label>Admitted Ward</label>
                                        <input id="AdmittedWard"
                                               name="AdmittedWard"
                                               class="form-control"
                                               value="@Model.AdmittedWard" />
                                    </div>

                                    <div class="col-md-6">
                                        <label>Referred Hospital</label>
                                        <input id="ReferredHospital"
                                               name="ReferredHospital"
                                               class="form-control"
                                               value="@Model.ReferredHospital" />
                                    </div>

                                    <div class="col-md-12">
                                        <label>Discharge Advice</label>
                                        <textarea id="DischargeAdvice"
                                                  name="DischargeAdvice"
                                                  class="form-control">@Model.DischargeAdvice</textarea>
                                    </div>

                                    <div class="col-md-12">
                                        <label>Follow Up Advice</label>
                                        <textarea id="FollowUpAdvice"
                                                  name="FollowUpAdvice"
                                                  class="form-control">@Model.FollowUpAdvice</textarea>
                                    </div>

                                </div>

                            </div>
                        </div>

                    </div>

                    <!-- MEDICATION -->
                    <div class="tab-pane fade" id="medication">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">

                                @await Html.PartialAsync("_MedicationPartial",
                                new MedicationPartialVm
                                {
                                    Medications = vm.Medications,
                                    MedicationMaster = vm.MedicationMaster
                                })

                            </div>
                        </div>
                    </div>

                    <!-- APPOINTMENT -->
                    <div class="tab-pane fade" id="appointment">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                @await Html.PartialAsync("_AppointmentPartial", vm.FollowUpSaveVm)
                            </div>
                        </div>
                    </div>

                    <!-- REFERRALS -->
                    <div class="tab-pane fade" id="referrals">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                @await Html.PartialAsync("_ReferralStatusPartial", Model.ReferralStatus)
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>

        <!-- STICKY ACTION BAR -->
        <div class="sticky-bottom bg-white border-top p-3 shadow-sm mt-3">

            <div class="d-flex justify-content-center gap-2 flex-wrap">

                <button type="submit" class="btn btn-primary px-5 rounded-pill">
                    💾 Update Case Sheet
                </button>

                @if (!Model.IsSentForApproval1 && !Model.Approval1Status && !Model.IsSentForApproval2 && !Model.Approval2Status)
                {
                    <button type="button"
                            class="btn btn-warning rounded-pill"
                            onclick="sendApproval(@Model.EMRId)">
                        🚀 Send for 1st Approval
                    </button>
                }

                @if (Model.IsSentForApproval1 && Model.Approval1Status && Model.IsSentForApproval2 && !Model.Approval2Status)
                {
                    <button type="button"
                            class="btn btn-info rounded-pill"
                            onclick="sendApproval(@Model.EMRId)">
                        🚀 Send for Final Approval
                    </button>
                }

                <a asp-action="PatientSearch" class="btn btn-outline-secondary rounded-pill px-4">
                    Cancel
                </a>

            </div>
        </div>

    </form>
</div>

<!-- AJAX + TOASTR -->
<script>
    function sendApproval(emrid) {

        if (!confirm("Send this case sheet for approval?"))
            return;

        $.ajax({
            url: '@Url.Action("SendForApproval", "Emergency")',
            type: 'POST',
            data: { emrid: emrid },
            success: function (res) {

                if (res.success) {
                    toastr.success(res.message);
                } else {
                    toastr.warning(res.message);
                }

            },
            error: function () {
                toastr.error("Something went wrong.");
            }
        });

    }
</script>

<style>
    .nav-pills .nav-link {
        font-weight: 600;
        background: #f1f3f5;
        color: #333;
    }

        .nav-pills .nav-link.active {
            background: #0d6efd;
            color: #fff;
        }

    textarea.form-control {
        resize: none;
    }
</style>