@model HMS.Entities.MASCategory

@{
    ViewData["Title"] = "Create Category";
}

<div class="card shadow">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Create Category</h4>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-md-8">
                    <label asp-for="CategoryName" class="form-label fw-bold"></label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DiscountPer" class="form-label fw-bold"></label>
                    <input asp-for="DiscountPer" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="InvestigationDiscountPer" class="form-label fw-bold"></label>
                    <input asp-for="InvestigationDiscountPer" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="TreatmentDiscountPer" class="form-label fw-bold"></label>
                    <input asp-for="TreatmentDiscountPer" class="form-control" />
                </div>

                <div class="col-md-4 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label fw-bold"></label>
                    </div>
                </div>

            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold">Save</button>
                <a asp-action="Index" class="btn btn-secondary fw-bold">Cancel</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}