@model HMS.Entities.MASCategory

@{
    ViewData["Title"] = "Category Details";
}

<div class="card shadow-sm">

    <div class="card-header bg-info text-white">
        <h4 class="mb-0 fw-bold">Category Details</h4>
    </div>

    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <strong>Category ID:</strong> @Model.CategoryId
            </div>

            <div class="col-md-6">
                <strong>Name:</strong> @Model.CategoryName
            </div>

            <div class="col-md-4">
                <strong>Discount %:</strong> @Model.DiscountPer
            </div>

            <div class="col-md-4">
                <strong>Investigation %:</strong> @Model.InvestigationDiscountPer
            </div>

            <div class="col-md-4">
                <strong>Treatment %:</strong> @Model.TreatmentDiscountPer
            </div>

            <div class="col-md-4">
                <strong>Status:</strong>
                <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </div>

            <div class="col-md-4">
                <strong>Deleted:</strong> @(Model.DelInd ? "Yes" : "No")
            </div>

        </div>

        <div class="mt-4">
            <a asp-action="Index" class="btn btn-secondary fw-bold">Back</a>
        </div>

    </div>
</div>