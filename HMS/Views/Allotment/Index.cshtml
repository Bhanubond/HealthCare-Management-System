@{
    ViewData["Title"] = "Allotment Queue";
    int deptId = ViewBag.DeptId ?? 0;
}

<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

<style>
    .page-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 3px 15px rgba(0,0,0,.08);
    }

    .page-header {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: white;
        padding: 16px 20px;
        border-radius: 12px 12px 0 0;
    }

    .wrap-text {
        white-space: normal !important;
        word-break: break-word;
    }

    table.dataTable td {
        vertical-align: middle;
    }

    .dt-buttons {
        margin-bottom: 10px;
    }

    .badge-pending {
        background: #ffc107;
        color: #000;
    }

    .badge-allotted {
        background: #198754;
        color: #fff;
    }
</style>

<div class="card page-card">

    <div class="page-header d-flex justify-content-between align-items-center">

        <h4 class="mb-0">
            <i class="bi bi-people-fill"></i>
            Allotment Queue
        </h4>

        <div style="width:280px">

            <input type="text"
                   id="AllotmentDateRange"
                   class="form-control"
                   placeholder="Select Date Range" />

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="tblAllotment"
                   class="table table-bordered table-hover align-middle"
                   style="width:100%">

                <thead class="table-primary">
                    <tr>
                        <th>OP No</th>
                        <th>Patient Name</th>
                        <th>Category</th>
                        <th>From Department</th>
                        <th>From Date</th>
                        <th>Status</th>
                        <th width="120">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <!-- ❌ REMOVE FOREACH COMPLETELY -->
                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- OFFCANVAS -->

<div class="offcanvas offcanvas-end"
     tabindex="-1"
     id="allotDrawer"
     style="width:500px;">

    <div class="offcanvas-header bg-primary text-white">

        <h5 class="offcanvas-title">

            Student / Doctor Allotment

        </h5>

        <button class="btn-close btn-close-white"
                data-bs-dismiss="offcanvas">
        </button>

    </div>

    <div class="offcanvas-body">

        <form asp-controller="Allotment"
              asp-action="SaveAllotment"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   id="PatientId"
                   name="PatientId" />

            <input type="hidden"
                   id="DeptId"
                   name="DeptId" />

            <input type="hidden"
                   id="ReferredId"
                   name="ReferredId" />

            <div id="patientContainer"
                 class="mb-3">
            </div>

            <div class="mb-3">

                <label class="form-label">
                    Student
                </label>

                <select class="form-select"
                        id="StudentId"
                        name="StudentId">

                    <option value="">
                        -- Select Student --
                    </option>

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Doctor
                </label>

                <select class="form-select"
                        id="DoctorId"
                        name="DoctorId">

                    <option value="">
                        -- Select Doctor --
                    </option>

                </select>

            </div>

            <div class="text-end">

                <button class="btn btn-success">

                    <i class="bi bi-save"></i>

                    Save Allotment

                </button>

            </div>

        </form>

    </div>

</div>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
@section Scripts {

    <script>

              var table;

        $(document).ready(function () {

            loadTable();

            var start = moment();
            var end = moment();

            $('#AllotmentDateRange').daterangepicker({
                startDate: start,
                endDate: end,
                locale: { format: 'DD/MM/YYYY' },
                ranges: {
                    'Today': [moment(), moment()],
                    'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                    'Last 7 Days': [moment().subtract(6, 'days'), moment()],
                    'Last 30 Days': [moment().subtract(29, 'days'), moment()],
                    'This Month': [moment().startOf('month'), moment().endOf('month')],
                    'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
                }
            });

            $('#AllotmentDateRange').on('apply.daterangepicker', function (ev, picker) {
                loadTable(picker.startDate, picker.endDate);
            });

        });

        function loadTable(fromDate, toDate) {

            var deptId = '@deptId';

            var from = fromDate ? fromDate.format('YYYY-MM-DD') : moment().format('YYYY-MM-DD');
            var to = toDate ? toDate.format('YYYY-MM-DD') : moment().format('YYYY-MM-DD');

            $.ajax({
                url: '/Allotment/GetPatients',
                type: 'GET',
                data: {
                    deptId: deptId,
                    fromDate: from,
                    toDate: to
                },
                success: function (data) {

                    if ($.fn.DataTable.isDataTable('#tblAllotment')) {
                        $('#tblAllotment').DataTable().destroy();
                    }

                    $('#tblAllotment').DataTable({
                        data: data,
                        columns: [
                            { data: 'opNo' },
                            { data: 'patientName' },
                            { data: 'categoryName' },
                            { data: 'fromDepartment' },
                            {
                                data: 'fromDate',
                                render: function (d) {
                                    return d ? moment(d).format('DD/MM/YYYY HH:mm') : '-';
                                }
                            },
                            {
                                data: 'allotmentStatus',
                                render: function (d) {
                                    if (d === "Pending")
                                        return '<span class="badge badge-pending">Pending</span>';
                                    return '<span class="badge badge-allotted">' + d + '</span>';
                                }
                            },
                            {
                                data: null,
                                render: function (row) {
                                    return `<button class="btn btn-primary btn-sm"
                                                onclick="openDrawer(${row.patientId}, ${row.toDeptId})">
                                                Allot
                                            </button>`;
                                }
                            }
                        ]
                    });
                }
            });
        }

        //=========================
        // OPEN OFFCANVAS
        //=========================

        function openDrawer(patientId, deptId) {

            $.ajax({

                url: '@Url.Action("GetAllotmentData", "Allotment")',

                type: 'GET',

                data: {

                    patientId: patientId,

                    deptId: deptId

                },

                success: function (data) {

                    $("#PatientId").val(data.patientId);
                    $("#DeptId").val(data.deptId);
                    $("#ReferredId").val(data.referredId);

                    $("#StudentId").empty()
                        .append('<option value="">-- Select Student --</option>');

                    $.each(data.students, function (i, s) {

                        $("#StudentId").append(

                            '<option value="' + s.studentId + '">' +
                            s.studentName +
                            '</option>'

                        );

                    });

                    $("#DoctorId").empty()
                        .append('<option value="">-- Select Doctor --</option>');

                    $.each(data.doctors, function (i, d) {

                        $("#DoctorId").append(

                            '<option value="' + d.doctorId + '">' +
                            d.doctorName +
                            '</option>'

                        );

                    });

                    $("#patientContainer").load(

                        '@Url.Action("GetPatientPartial", "Registration")?patientId='
                        + patientId

                    );

                    bootstrap.Offcanvas.getOrCreateInstance(

                        document.getElementById('allotDrawer')

                    ).show();

                },

                error: function (xhr) {

                    toastr.error(xhr.responseText);

                }

            });

        }

    </script>

}