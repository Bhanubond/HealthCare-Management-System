@model List<AllotmentViewModel>

@{
    ViewBag.Title = "General Medicine - Allotment Queue";
    int deptId = ViewBag.DeptId ?? 0;
}

<h3 class="mb-3">Allotment Queue</h3>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No patients found for this department.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>OP No</th>
                <th>Patient Name</th>
                <th>Category</th>
                <th>From Department</th>
                <th>From Date</th>
                <th>Status</th>
                <th style="width:180px;">Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OpNo</td>
                    <td>@item.PatientName</td>
                    <td>@item.CategoryName</td>
                    <td>@item.FromDepartment</td>
                    <td>
                        @(item.FromDate.HasValue
                                        ? item.FromDate.Value.ToString("dd-MM-yyyy HH:mm")
                                        : "-")
            </td>
            <td>
                <span class="badge bg-warning text-dark">
                    @item.AllotmentStatus
                </span>
            </td>

                    <td>
                        <button class="btn btn-sm btn-success"
                                onclick="openAllotModal(@item.PatientId, @item.FromDeptId)">
                            Allot
                        </button>
                    </td>
                </tr>
                }
        </tbody>
    </table>
}