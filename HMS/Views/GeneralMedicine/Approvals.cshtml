@{
    ViewData["Title"] = "Approval Queue";
}

<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

<style>
    .page-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 3px 15px rgba(0,0,0,.08);
    }

    .page-header {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: #fff;
        padding: 16px 20px;
        border-radius: 12px 12px 0 0;
    }

    table.dataTable td {
        vertical-align: middle;
    }

    .dt-buttons {
        margin-bottom: 10px;
    }

    .badge-stage {
        font-size: 12px;
        padding: 5px 8px;
        border-radius: 8px;
    }
</style>

<div class="card page-card">

    <div class="page-header d-flex justify-content-between align-items-center">

        <h4 class="mb-0">
            <i class="bi bi-check2-circle"></i>
            Approval Queue
        </h4>

        <div style="width:280px">
            <input type="text"
                   id="ApprovalDateRange"
                   class="form-control"
                   placeholder="Select Date Range" />
        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="tblApprovalQueue"
                   class="table table-bordered table-hover align-middle"
                   style="width:100%">

                <thead class="table-primary">
                    <tr>
                        <th>OP No</th>
                        <th>Patient Name</th>
                        <th>Doctor</th>
                        <th>Student</th>
                        <th>Department</th>
                        <th>Category</th>
                        <th>Allot Date</th>
                        <th>Stage</th>
                        <th width="140">View</th>
                        <th width="140">Action</th>
                    </tr>
                </thead>

            </table>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

@section Scripts {

    <script>

        $(function () {

            loadApprovalQueue();

            $('#ApprovalDateRange').daterangepicker({

                startDate: moment(),
                endDate: moment(),

                locale: { format: 'DD/MM/YYYY' },

                ranges: {
                    'Today': [moment(), moment()],
                    'Yesterday': [moment().subtract(1,'days'), moment().subtract(1,'days')],
                    'Last 7 Days': [moment().subtract(6,'days'), moment()],
                    'Last 30 Days': [moment().subtract(29,'days'), moment()],
                    'This Month': [moment().startOf('month'), moment().endOf('month')],
                    'Last Month': [moment().subtract(1,'month').startOf('month'),
                                   moment().subtract(1,'month').endOf('month')]
                }

            });

            $('#ApprovalDateRange').on('apply.daterangepicker', function (ev, picker) {

                loadApprovalQueue(
                    picker.startDate,
                    picker.endDate
                );

            });

        });

        function loadApprovalQueue(fromDate, toDate) {

            var from = fromDate ? fromDate.format('YYYY-MM-DD') : moment().format('YYYY-MM-DD');
            var to = toDate ? toDate.format('YYYY-MM-DD') : moment().format('YYYY-MM-DD');

            $.ajax({

                url: '/GeneralMedicine/GetApprovalQueue',
                type: 'GET',
                data: { fromDate: from, toDate: to },

                success: function (data) {

                    if ($.fn.DataTable.isDataTable('#tblApprovalQueue')) {
                        $('#tblApprovalQueue').DataTable().destroy();
                    }

                    $('#tblApprovalQueue').DataTable({

                        data: data,
                        responsive: true,
                        dom: 'Bfrtip',
                        buttons: ['excelHtml5', 'pdfHtml5', 'print'],

                        columns: [

                            { data: 'opNo' },
                            { data: 'patientName' },
                            { data: 'doctorName' },
                            { data: 'studentName' },
                            { data: 'departmentName' },
                            { data: 'categoryName' },
                            {
                                data: 'allotDate',
                                render: function (d) {
                                    return moment(d).format('DD/MM/YYYY');
                                }
                            },

                            {
                                data: null,
                                render: function (row) {

                                    if (!row.isSentForApproval1) {
                                        return `<span class="badge bg-warning badge-stage">Pending 1st Approval</span>`;
                                    }
                                    else if (row.isSentForApproval1 && !row.approval1Status) {
                                        return `<span class="badge bg-info badge-stage">1st Approval Pending</span>`;
                                    }
                                    else if (row.approval1Status && !row.isSentForApproval2) {
                                        return `<span class="badge bg-primary badge-stage">Ready for Final Approval</span>`;
                                    }
                                    else if (row.isSentForApproval2 && !row.approval2Status) {
                                        return `<span class="badge bg-warning text-dark badge-stage">Final Approval Pending</span>`;
                                    }
                                    else if (row.approval2Status) {
                                        return `<span class="badge bg-success badge-stage">Approved</span>`;
                                    }

                                    return '';
                                }
                            },

                            {
                                data: null,
                                orderable: false,
                                searchable: false,
                                render: function (row) {

                                    return `
                                        <a href="/GeneralMedicine/EditCaseSheet?gmId=${row.gmid}"
                                           class="btn btn-primary btn-sm">
                                            <i class="bi bi-eye"></i> View
                                        </a>`;
                                }
                            },
                            {
                                data: null,
                                orderable: false,
                                searchable: false,
                                render: function (row) {

                                        return `
                                            <button class="btn btn-success btn-sm"
                                                    onclick="sendForApproval(${row.gmid})">
                                                Approve
                                            </button>`;
                                }
                            }

                        ]

                    });

                },

                error: function () {
                    toastr.error("Unable to load approval queue.");
                }

            });

        }

                        function sendForApproval(gmId) {

            $.ajax({
                url: '/GeneralMedicine/SendForApproval',
                type: 'POST',
                data: { gmId: gmId },

                success: function (res) {

                    if (res.success) {
                        toastr.success(res.message || "Approved successfully");

                        // RELOAD TABLE PROPERLY
                        loadApprovalQueue();
                    }
                    else {
                        toastr.error(res.message || "Approval failed");
                    }
                },

                error: function () {
                    toastr.error("Server error while approving");
                }
            });
        }

    </script>

}