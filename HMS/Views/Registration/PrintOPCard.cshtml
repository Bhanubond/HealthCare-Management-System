@model HMS.Entities.OPDPatientRegistration

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>OP Card</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            background: #f2f2f2;
            font-family: Arial;
        }

        .op-card {
            width: 900px;
            margin: 20px auto;
            background: white;
            border: 3px solid #0d6efd;
            padding: 20px;
            border-radius: 8px;
        }

        .hospital {
            text-align: center;
        }

            .hospital h2 {
                margin: 0;
                color: #0d6efd;
                font-weight: bold;
            }

            .hospital p {
                margin: 2px;
            }

        .section-title {
            background: #0d6efd;
            color: white;
            padding: 5px;
            font-weight: bold;
            margin-top: 15px;
        }

        table {
            width: 100%;
        }

        td {
            padding: 6px;
        }

        .label {
            font-weight: bold;
            width: 180px;
        }

        .photo {
            width: 120px;
            height: 120px;
            border: 1px solid #ccc;
            object-fit: cover;
        }

        .barcode {
            width: 320px;
        }

        .qr {
            width: 140px;
        }

        @@media print {
            .noprint

        {
            display: none;
        }

        body {
            background: white;
        }

        .op-card {
            border: none;
            width: 100%;
            margin: 0;
        }

        }

        .barcode-section {
            margin-top: 25px;
        }
    </style>

</head>

<body>

    <div class="op-card">

        <div class="hospital">

            <h2>@ViewBag.Hospital.HospitalName</h2>
            <h3>@ViewBag.Hospital.TagLine</h3>
            <p>@ViewBag.Hospital.Address</p>
            <p>@ViewBag.Hospital.Phone</p>

        </div>

        <div class="section-title">
            OPD REGISTRATION CARD
        </div>

        <table>

            <tr>

                <td>

                    <table>

                        <tr>

                            <td class="label">UHID</td>

                            <td>@Model.UHID</td>

                        </tr>

                        <tr>

                            <td class="label">OP Number</td>

                            <td>@Model.OpNo</td>

                        </tr>

                        <tr>

                            <td class="label">Registration Date</td>

                            <td>@Model.RegDate.ToString("dd-MM-yyyy hh:mm tt")</td>

                        </tr>

                        <tr>

                            <td class="label">Category</td>

                            <td>@Model.CategoryId</td>

                        </tr>

                    </table>

                </td>

                <td align="right">

                    @if (!string.IsNullOrEmpty(Model.PatientPicture))
                    {
                        <img class="photo"
                             src="~/uploads/patients/@Model.PatientPicture" />
                    }
                    else
                    {
                        <img class="photo"
                             src="~/images/user.png" />
                    }

                </td>

            </tr>

        </table>

        <div class="section-title">
            Patient Details
        </div>

        <table>

            <tr>

                <td class="label">Patient Name</td>

                <td>@Model.Title @Model.PatientName</td>

                <td class="label">Gender</td>

                <td>@Model.Gender</td>

            </tr>

            <tr>

                <td class="label">DOB</td>

                <td>@Model.Dob?.ToString("dd-MM-yyyy")</td>

                <td class="label">Phone</td>

                <td>@Model.Phone</td>

            </tr>

            <tr>

                <td class="label">Father/Husband</td>

                <td colspan="3">@Model.FatherOrHusband</td>

            </tr>

            <tr>

                <td class="label">Address</td>

                <td colspan="3">@Model.Address</td>

            </tr>

            <tr>

                <td class="label">Aadhar</td>

                <td>@Model.AadharNo</td>

                <td class="label">Paid</td>

                <td>₹ @Model.PaidAmount</td>

            </tr>

        </table>

        <div class="section-title">
            Barcode & QR Code
        </div>
        <div class="barcode-section">
        <div class="row">

            <div class="col-6 text-center">

                <img src="data:image/png;base64,@ViewBag.BarCode"
                     width="350" />

                <div class="text-center fw-bold">
                    @Model.UHID
                </div>

            </div>

            <div class="col-6 text-center">

                <img src="data:image/png;base64,@ViewBag.QRCode"
                     width="150"
                     height="150" />

                <br />

                Scan Patient

            </div>

        </div>
        </div>

        <hr />

        <div class="text-center">

            <b>

                Please bring this OP Card during every hospital visit.

            </b>

        </div>

        <div class="text-center mt-4 noprint">

            <button class="btn btn-primary"
                    onclick="window.print();">

                🖨 Print

            </button>

            <button class="btn btn-danger"
                    onclick="window.close();">

                Close

            </button>

        </div>

    </div>

</body>

</html>