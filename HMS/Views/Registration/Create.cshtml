@model HMS.Models.RegistrationFormViewModel

@{
    ViewData["Title"] = "OPD Patient Registration";
}

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🏥 OPD Patient Registration</h3>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="row">

            <div class="col-lg-6">
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-primary text-white">
                        Patient Information
                    </div>

                    <div class="card-body">

                        <div class="row">

                            <div class="col-md-4">
                                <label>Title</label>
                                <select asp-for="Patient.Title" class="form-control">
                                    <option value="">Select</option>
                                    @foreach (var t in Model.Titles)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-8">
                                <label>Patient Name *</label>
                                <input asp-for="Patient.PatientName" class="form-control"/>
                            </div>

                        </div>

                        <div class="row mt-2">

                            <div class="col-md-6">
                                <label>Father / Husband</label>
                                <input asp-for="Patient.FatherOrHusband" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label>Date of Birth</label>
                                <input asp-for="Patient.Dob" type="date" class="form-control" />
                            </div>

                        </div>

                        <div class="row mt-2">

                            <div class="col-md-6">
                                <label>Gender</label>
                                <select asp-for="Patient.Gender" class="form-control">
                                    <option value="">Select</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label>Phone *</label>
                                <input asp-for="Patient.Phone" class="form-control" maxlength="10" />
                            </div>

                        </div>

                        <div class="row mt-2">

                            <div class="col-md-6">
                                <label>Aadhar No</label>
                                <input asp-for="Patient.AadharNo" class="form-control" maxlength="12" />
                            </div>

                            <div class="col-md-6">
                                <label>Category</label>
                                <select asp-for="Patient.CategoryId" class="form-control"
                                        asp-items="@(new SelectList(Model.Categories, "CategoryId", "CategoryName"))">
                                    <option value="">Select Category</option>
                                </select>
                            </div>

                        </div>

                        <div class="mt-2">
                            <label>Patient Photo</label>
                            <input type="file" name="PatientImage" class="form-control" id="patientImage" />
                            <img id="previewImg" style="width:100px;height:100px;margin-top:10px;display:none;" />
                        </div>

                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        Address Details
                    </div>

                    <div class="card-body">

                        <label>Address</label>
                        <textarea asp-for="Patient.Address" class="form-control"></textarea>

                        <div class="row mt-2">

                            <div class="col-md-6">
                                <label>Country</label>
                                <select asp-for="Patient.CountryId" id="CountryId"
                                        class="form-control"
                                        asp-items="@(new SelectList(Model.Countries, "CountryId", "CountryName"))">
                                    <option value="">Select</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label>State</label>
                                <select asp-for="Patient.StateId" id="StateId" class="form-control"></select>
                            </div>

                        </div>

                        <div class="row mt-2">

                            <div class="col-md-6">
                                <label>Mandal</label>
                                <select asp-for="Patient.MandalId" id="MandalId" class="form-control"></select>
                            </div>

                            <div class="col-md-6">
                                <label>City</label>
                                <select asp-for="Patient.CityId" id="CityId" class="form-control"></select>
                            </div>

                        </div>

                    </div>
                </div>

            </div>

            <div class="col-lg-6">

                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-success text-white">
                        Billing Details
                    </div>

                    <div class="card-body">

                        <label>Total Amount</label>
                        <input asp-for="Patient.TotalAmount" id="TotalAmount" class="form-control" />

                        <label class="mt-2">Discount %</label>
                        <input asp-for="Patient.DiscountPer" id="DiscountPer" class="form-control" />

                        <label class="mt-2">Net Amount</label>
                        <input asp-for="Patient.NetAmount" id="NetAmount" class="form-control" readonly />

                        <label class="mt-2">Paid Amount</label>
                        <input asp-for="Patient.PaidAmount" id="PaidAmount" class="form-control" readonly />

                        <label class="mt-2">Payment Mode</label>
                        <select asp-for="Patient.PaymodeId"
                                class="form-control"
                                asp-items="@(new SelectList(Model.PaymentModes, "PaymodeId", "PaymodeName"))">
                            <option value="">Select</option>
                        </select>

                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body text-center">

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            💾 Register Patient
                        </button>

                    </div>
                </div>

            </div>

        </div>

    </form>
</div>


@section Scripts {

    <script>     
        function showError(msg) {
            toastr.error(msg);
        }

        $("#patientImage").change(function () {
            var file = this.files[0];

            if (file) {
                var ext = file.name.split('.').pop().toLowerCase();

                if ($.inArray(ext, ['jpg', 'jpeg', 'png']) == -1) {
                    showError("Only JPG / JPEG / PNG allowed");
                    $(this).val('');
                    return;
                }

                var reader = new FileReader();
                reader.onload = function (e) {
                    $("#previewImg").show();
                    $("#previewImg").attr("src", e.target.result);
                };
                reader.readAsDataURL(file);
            }
        });

        function calculateNet() {
            let total = parseFloat($("#TotalAmount").val()) || 0;
            let discount = parseFloat($("#DiscountPer").val()) || 0;

            let net = total - (total * discount / 100);
            $("#NetAmount").val(net.toFixed(2));
            $("#PaidAmount").val(net.toFixed(2));
        }

        $("#TotalAmount, #DiscountPer").on("input", function () {
            calculateNet();
        });

               function validateForm() {

            let title = $("#Patient_Title").val();
            if (!title) {
                showError("Select Title");
                $("#Patient_Title").focus();
                return false;
            }

            let name = $("#Patient_PatientName").val()?.trim();
            if (!name) {
                showError("Patient Name is required");
                $("#Patient_PatientName").focus();
                return false;
            }

            let dob = $("#Patient_Dob").val();
            if (!dob) {
                showError("Date of Birth is required");
                $("#Patient_Dob").focus();
                return false;
            }

            let gender = $("#Patient_Gender").val();
            if (!gender) {
                showError("Select Gender");
                $("#Patient_Gender").focus();
                return false;
            }

            let phone = $("#Patient_Phone").val()?.trim();
            if (!phone) {
                showError("Phone is required");
                $("#Patient_Phone").focus();
                return false;
            }

            if (!/^[0-9]{10}$/.test(phone)) {
                showError("Phone must be 10 digits");
                $("#Patient_Phone").focus();
                return false;
            }

            let aadhar = $("#Patient_AadharNo").val()?.trim();
            if (aadhar && !/^[0-9]{12}$/.test(aadhar)) {
                showError("Aadhar must be 12 digits");
                $("#Patient_AadharNo").focus();
                return false;
            }

            let category = $("#Patient_CategoryId").val();
            if (!category) {
                showError("Select Category");
                $("#Patient_CategoryId").focus();
                return false;
            }

            let address = $("#Patient_Address").val()?.trim();
            if (!address) {
                showError("Address is required");
                $("#Patient_Address").focus();
                return false;
            }

            let country = $("#CountryId").val();
            if (!country) {
                showError("Select Country");
                $("#CountryId").focus();
                return false;
            }

            let state = $("#StateId").val();
            if (!state) {
                showError("Select State");
                $("#StateId").focus();
                return false;
            }

            let mandal = $("#MandalId").val();
            if (!mandal) {
                showError("Select Mandal");
                $("#MandalId").focus();
                return false;
            }

            let city = $("#CityId").val();
            if (!city) {
                showError("Select City");
                $("#CityId").focus();
                return false;
            }

            let total = parseFloat($("#TotalAmount").val()) || 0;
            if (total <= 0) {
                showError("Enter valid Total Amount");
                $("#TotalAmount").focus();
                return false;
            }

            let discount = parseFloat($("#DiscountPer").val()) || 0;
            if (discount < 0 || discount > 100) {
                showError("Discount must be 0–100");
                $("#DiscountPer").focus();
                return false;
            }

            let paid = parseFloat($("#Patient_PaidAmount").val()) || 0;
            if (paid < 0) {
                showError("Enter valid Paid Amount");
                $("#Patient_PaidAmount").focus();
                return false;
            }

            if (paid > total) {
                showError("Paid cannot be greater than Total");
                $("#Patient_PaidAmount").focus();
                return false;
            }

            let paymode = $("#Patient_PaymodeId").val();
            if (!paymode) {
                showError("Select Payment Mode");
                $("#Patient_PaymodeId").focus();
                return false;
            }

            let file = $("#patientImage")[0].files[0];
            if (file) {
                let ext = file.name.split('.').pop().toLowerCase();
                if ($.inArray(ext, ['jpg', 'jpeg', 'png']) == -1) {
                    showError("Only JPG / JPEG / PNG allowed");
                    $("#patientImage").focus();
                    return false;
                }
            }

            return true;
        }

       


        $("#CountryId").change(function () {

            $("#StateId").empty();
            $("#MandalId").empty();
            $("#CityId").empty();

            $.getJSON('/Registration/GetStatesByCountry', { countryId: $(this).val() }, function (data) {

                $("#StateId").append('<option value="">Select</option>');

                $.each(data, function (i, item) {
                    $("#StateId").append('<option value="' + item.stateId + '">' + item.stateName + '</option>');
                });

            });
        });

        $("#StateId").change(function () {

            $("#MandalId").empty();
            $("#CityId").empty();

            $.getJSON('/Registration/GetMandalsByState', { stateId: $(this).val() }, function (data) {

                $("#MandalId").append('<option value="">Select</option>');

                $.each(data, function (i, item) {
                    $("#MandalId").append('<option value="' + item.mandalId + '">' + item.mandalName + '</option>');
                });

            });
        });

        $("#MandalId").change(function () {

            $("#CityId").empty();

            $.getJSON('/Registration/GetCitiesByMandal', { mandalId: $(this).val() }, function (data) {

                $("#CityId").append('<option value="">Select</option>');

                $.each(data, function (i, item) {
                    $("#CityId").append('<option value="' + item.cityId + '">' + item.cityName + '</option>');
                });

            });
        });

        $("form").on("submit", function (e) {
            if (!validateForm()) {
                e.preventDefault();
                return false;
            }
        });

    </script>

}