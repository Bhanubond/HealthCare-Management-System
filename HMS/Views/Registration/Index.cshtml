@model HMS.Models.OPDSearchViewModel

@{
    ViewData["Title"] = "OPD Patient Registration";
}

<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

<style>
    .page-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 3px 15px rgba(0,0,0,.08);
    }

    .page-header {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: white;
        padding: 16px 20px;
        border-radius: 12px 12px 0 0;
    }

    .filter-card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 10px rgba(0,0,0,.05);
    }

    table.dataTable td {
        vertical-align: middle;
    }

    .dt-buttons {
        margin-bottom: 10px;
    }
</style>

<div class="card page-card">

    <!-- HEADER -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">OPD Patient Registration</h4>

        <div style="width:280px">
            <input type="text"
                   id="RegDateRange"
                   class="form-control"
                   placeholder="Select Date Range" />
        </div>
    </div>

    <div class="card-body">

        <!-- FILTERS -->
        <div class="card filter-card p-3 mb-3">

            <div class="row g-2">

                <div class="col-md-2">
                    <input id="OPNo" class="form-control" placeholder="OP No" />
                </div>

                <div class="col-md-2">
                    <input id="Phone" class="form-control" placeholder="Phone" />
                </div>

                <div class="col-md-3">
                    <input id="PatientName" class="form-control" placeholder="Patient Name" />
                </div>

                <div class="col-md-2">
                    <input id="AadharNo" class="form-control" placeholder="Aadhar No" />
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary w-100" onclick="loadData()">
                        Search
                    </button>
                </div>

            </div>
        </div>

        <!-- TABLE -->
        <div class="table-responsive">

            <table id="tblOPD"
                   class="table table-bordered table-hover align-middle"
                   style="width:100%">

                <thead class="table-primary">
                    <tr>
                        <th>UHID</th>
                        <th>OP No</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Aadhar</th>
                        <th>Reg Date</th>
                        <th width="120">Action</th>
                    </tr>
                </thead>

                <tbody></tbody>

            </table>

        </div>

    </div>
</div>

<!-- 1. jQuery FIRST (must be before everything) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- 2. Bootstrap (optional but usually used) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- 3. Moment (for daterangepicker) -->
<script src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>

<!-- 4. Daterangepicker -->
<script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />

<!-- 5. DataTables -->
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

<!-- 6. DataTables Buttons -->
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script><script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

<script>

    var table;

    $(document).ready(function () {

        // Date Range Picker (same as Treatment)
        var start = moment();
        var end = moment();

        $('#RegDateRange').daterangepicker({

            startDate: start,
            endDate: end,

            locale: { format: 'DD/MM/YYYY' },

            ranges: {
                'Today': [moment(), moment()],
                'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                'Last 7 Days': [moment().subtract(6, 'days'), moment()],
                'Last 30 Days': [moment().subtract(29, 'days'), moment()],
                'This Month': [moment().startOf('month'), moment().endOf('month')],
                'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
            }

        });

        loadData();
    });

    function loadData() {

        if ($.fn.DataTable.isDataTable('#tblOPD')) {
            $('#tblOPD').DataTable().destroy();
        }

        table = $('#tblOPD').DataTable({

            processing: true,
            serverSide: false,

            ajax: {
                url: '/Registration/GetOPDPatients',
                type: 'GET',

                data: function (d) {

                    var range = $('#RegDateRange').data('daterangepicker');

                    d.OPNo = $('#OPNo').val();
                    d.Phone = $('#Phone').val();
                    d.PatientName = $('#PatientName').val();
                    d.AadharNo = $('#AadharNo').val();

                    if (range) {
                        d.FromDate = range.startDate.format('YYYY-MM-DD');
                        d.ToDate = range.endDate.format('YYYY-MM-DD');
                    }
                },

                dataSrc: 'data'
            },

            dom: 'Bfrtip',

            buttons: [
                'excelHtml5',
                'pdfHtml5',
                'print'
            ],

            columns: [

                { data: 'uhid' },
                { data: 'opNo' },
                { data: 'patientName' },
                { data: 'phone' },
                { data: 'aadharNo' },

                {
                    data: 'regDate',
                    render: function (d) {
                        return d ? moment(d).format('DD-MM-YYYY') : '-';
                    }
                },

                {
                    data: null,
                    render: function (row) {
                        return `
                            <a class="btn btn-sm btn-primary" href="/Registration/Details/${row.patientId}">View</a>
                            <a class="btn btn-sm btn-warning" href="/Registration/Edit/${row.patientId}">Edit</a>
                        `;
                    }
                }
            ]
        });
    }

</script>