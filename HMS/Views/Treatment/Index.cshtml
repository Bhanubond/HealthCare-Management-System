@{
    ViewData["Title"] = "Treatment Queue";
    int deptId = ViewBag.DeptId ?? 0;
}

<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

<style>
    .page-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 3px 15px rgba(0,0,0,.08);
    }

    .page-header {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: white;
        padding: 16px 20px;
        border-radius: 12px 12px 0 0;
    }

    table.dataTable td {
        vertical-align: middle;
    }

    .dt-buttons {
        margin-bottom: 10px;
    }

    .badge-pending {
        background: #ffc107;
        color: #000;
    }

    .badge-allotted {
        background: #198754;
        color: #fff;
    }
</style>

<div class="card page-card">

    <div class="page-header d-flex justify-content-between align-items-center">

        <h4 class="mb-0">
            <i class="bi bi-clipboard2-pulse-fill"></i>
            Treatment Queue
        </h4>

        <div style="width:280px">

            <input type="text"
                   id="TreatmentDateRange"
                   class="form-control"
                   placeholder="Select Date Range" />

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="tblTreatment"
                   class="table table-bordered table-hover align-middle"
                   style="width:100%">

                <thead class="table-primary">
                    <tr>
                        <th>OP No</th>
                        <th>Patient Name</th>
                        <th>Category</th>
                        <th>Department</th>
                        <th>Doctor</th>
                        <th>Student</th>
                        <th>Allotted On</th>
                        <th width="100">Action</th>
                    </tr>
                </thead>

                <tbody></tbody>

            </table>

        </div>

    </div>

</div>

<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

@section Scripts
{
    <script>

        $(document).ready(function () {

            loadTreatmentQueue();

            var start = moment();
            var end = moment();

            $('#TreatmentDateRange').daterangepicker({

                startDate: start,
                endDate: end,

                locale: { format: 'DD/MM/YYYY' },

                ranges: {
                    'Today': [moment(), moment()],
                    'Yesterday': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                    'Last 7 Days': [moment().subtract(6, 'days'), moment()],
                    'Last 30 Days': [moment().subtract(29, 'days'), moment()],
                    'This Month': [moment().startOf('month'), moment().endOf('month')],
                    'Last Month': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
                }

            });

            $('#TreatmentDateRange').on('apply.daterangepicker', function (ev, picker) {

                loadTreatmentQueue(
                    picker.startDate,
                    picker.endDate
                );

            });

        });

        function loadTreatmentQueue(fromDate, toDate) {

            var deptId = @deptId;

            var from = fromDate
                ? fromDate.format('YYYY-MM-DD')
                : moment().format('YYYY-MM-DD');

            var to = toDate
                ? toDate.format('YYYY-MM-DD')
                : moment().format('YYYY-MM-DD');

            $.ajax({

                url: '/Treatment/GetTreatmentQueue',

                type: 'GET',

                data: {
                    deptId: deptId,
                    fromDate: from,
                    toDate: to
                },

                success: function (data) {

                    if ($.fn.DataTable.isDataTable('#tblTreatment')) {
                        $('#tblTreatment').DataTable().destroy();
                    }

                    $('#tblTreatment').DataTable({

                        data: data,

                        dom: 'Bfrtip',

                        buttons: [
                            'excelHtml5',
                            'pdfHtml5',
                            'print'
                        ],

                        columns: [

                            { data: 'opNo' },
                            { data: 'patientName' },
                            { data: 'categoryName' },
                            { data: 'departmentName' },
                            { data: 'doctorName' },
                            { data: 'studentName' },

                            {
                                data: 'allotDate',
                                render: function (d) {
                                    return d
                                        ? moment(d).format('DD/MM/YYYY HH:mm')
                                        : '-';
                                }
                            },

                            {
                                data: null,
                                orderable: false,
                                searchable: false,
                                // render: function (row) {

                                //     return `<a href="/GeneralMedicine/TreatmentDetails?patientId=${row.patientId}"
                                //                 class="btn btn-success btn-sm">
                                //                 Treat
                                //             </a>`;
                                // }
                                        render: function (row) {

                                        return `<a href="/Treatment/TreatmentDetails?deptId=${row.deptId}&patientId=${row.patientId}"
                                                    class="btn btn-success btn-sm">
                                                    Treat
                                                </a>`;
                                    }
                            }
                        ]
                    });

                },

                        error: function (xhr) {
            console.log("ERROR:", xhr.responseText);
            toastr.error("Failed to load treatment queue.");
        }

            });

        }

    </script>
}