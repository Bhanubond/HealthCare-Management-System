@model HMS.Models.EMRCasesheetScreenVm

@{
    var vm = Model ?? new HMS.Models.EMRCasesheetScreenVm();
}
<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI', sans-serif;
    }

    .cardx {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        border: none;
    }

    .badge-soft {
        background: #f1f3f9;
        padding: 6px 12px;
        border-radius: 50px;
        font-size: 12px;
        color: #444;
    }


    .nav-pills .nav-link {
        border-radius: 50px;
        color: #555;
        background: #f1f3f9;
        padding: 8px 18px;
    }

        .nav-pills .nav-link.active {
            background: #0d6efd;
            color: #fff;
        }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1px solid #ddd;
        min-height: 42px;
    }

    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 .15rem rgba(13,110,253,.15);
    }



    label {
        font-weight: 600;
        font-size: 14px;
        color: #444;
        margin-bottom: 5px;
    }


    .tab-pane .card {
        border-radius: 14px;
    }

    .sticky-bar {
        position: sticky;
        bottom: 0;
        background: #ffffff;
        padding: 15px;
        border-top: 1px solid #eee;
        z-index: 100;
    }


    #btnSave {
        font-size: 16px;
        font-weight: 600;
        box-shadow: 0 5px 15px rgba(13,110,253,.25);
    }


    #TriageCategory option[value="Red"] {
        color: red;
    }



    #TriageCategory option[value="Yellow"] {
        color: #d39e00;
    }



    #TriageCategory option[value="Green"] {
        color: green;
    }



    #TriageCategory option[value="Black"] {
        color: black;
    }


    @@media(max - width:768px)
    {
        .badge-soft

    {
        font-size: 11px;
    }


    .nav-pills {
        overflow-x: auto;
        flex-wrap: nowrap;
    }


        .nav-pills .nav-link {
            white-space: nowrap;
        }

    }
</style>

<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

<div class="container-fluid py-3">

    <!-- HEADER -->
    <div class="cardx p-3 mb-3">
        <div class="d-flex justify-content-between flex-wrap gap-3">

            <div>
                <h5 class="mb-0">🚑 Emergency Department Case Sheet</h5>
                <small class="text-muted">OP No: @vm.OpNo</small>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <span class="badge-soft">👤 @vm.PatientName</span>
                <span class="badge-soft">🎂 @vm.Age yrs</span>
                <span class="badge-soft">⚧ @vm.Gender</span>
                <span class="badge-soft">👨‍⚕️ @vm.DoctorName</span>
                <span class="badge-soft">🎓 @vm.StudentName</span>
            </div>

        </div>
    </div>

    <div class="cardx">

        <!-- NAVIGATION -->
        <div class="p-3 border-bottom">

            <ul class="nav nav-pills gap-2">

                <li class="nav-item">
                    <button class="nav-link active rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#arrival"
                            type="button">
                        🚑 Arrival & Triage
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#history"
                            type="button">
                        📋 History
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#vitals"
                            type="button">
                        ❤️ Vitals
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#exam"
                            type="button">
                        🔍 Examination
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#treatment"
                            type="button">
                        💉 Treatment
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link rounded-pill"
                            data-bs-toggle="tab"
                            data-bs-target="#disposition"
                            type="button">
                        🏥 Disposition
                    </button>
                </li>

            </ul>

        </div>

        <div class="p-3 bg-light">

            <div class="tab-content">

                <!-- ARRIVAL TAB -->

                <div class="tab-pane fade show active" id="arrival">

                    <div class="card border-0 shadow-sm">

                        <div class="card-body">

                            <div class="row g-3">

                                <div class="col-md-4">
                                    <label class="form-label">Arrival Mode</label>
                                    <select id="ArrivalMode" class="form-select">
                                        <option value="">Select</option>
                                        <option>Walk-in</option>
                                        <option>Ambulance</option>
                                        <option>Referral</option>
                                        <option>Police</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Arrival Time</label>
                                    <input type="datetime-local"
                                           id="ArrivalTime"
                                           class="form-control">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Brought By</label>
                                    <input id="BroughtBy"
                                           class="form-control">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Triage Category</label>
                                    <select id="TriageCategory"
                                            class="form-select">

                                        <option value="">Select</option>
                                        <option>Red</option>
                                        <option>Yellow</option>
                                        <option>Green</option>
                                        <option>Black</option>

                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Triage Time</label>

                                    <input type="datetime-local"
                                           id="TriageTime"
                                           class="form-control">
                                </div>

                                <div class="col-md-12">

                                    <label class="form-label">
                                        Triage Notes
                                    </label>

                                    <textarea id="TriageNotes"
                                              rows="3"
                                              class="form-control"></textarea>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- HISTORY -->

                <div class="tab-pane fade" id="history">

                    <div class="card border-0 shadow-sm">

                        <div class="card-body">

                            <div class="row g-3">

                                <div class="col-md-6">

                                    <label>Chief Complaint</label>

                                    <textarea id="ChiefComplaint"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>History Of Present Illness</label>

                                    <textarea id="HistoryOfPresentIllness"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Past Medical History</label>

                                    <textarea id="PastMedicalHistory"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Past Surgical History</label>

                                    <textarea id="PastSurgicalHistory"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Family History</label>

                                    <textarea id="FamilyHistory"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Personal History</label>

                                    <textarea id="PersonalHistory"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Drug History</label>

                                    <textarea id="DrugHistory"
                                              class="form-control"></textarea>

                                </div>

                                <div class="col-md-6">

                                    <label>Allergy History</label>

                                    <textarea id="AllergyHistory"
                                              class="form-control"></textarea>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
                <!-- VITALS TAB -->

                <div class="tab-pane fade" id="vitals">

                    <div class="card border-0 shadow-sm">

                        <div class="card-body">

                            <div class="row g-3">


                                <div class="col-md-3">
                                    <label class="form-label">
                                        Blood Pressure
                                    </label>

                                    <input id="BloodPressure"
                                           class="form-control"
                                           placeholder="120/80">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        Pulse Rate
                                    </label>

                                    <input id="PulseRate"
                                           class="form-control"
                                           placeholder="Pulse">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        Temperature °C
                                    </label>

                                    <input id="Temperature"
                                           class="form-control">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        Respiratory Rate
                                    </label>

                                    <input id="RespiratoryRate"
                                           class="form-control">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        SpO₂
                                    </label>

                                    <input id="SpO2"
                                           class="form-control">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        Weight (Kg)
                                    </label>

                                    <input id="Weight"
                                           class="form-control">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        Height (cm)
                                    </label>

                                    <input id="Height"
                                           class="form-control">
                                </div>


                                <div class="col-md-2">
                                    <label class="form-label">
                                        BMI
                                    </label>

                                    <input id="BMI"
                                           readonly
                                           class="form-control">
                                </div>


                                <div class="col-md-2">

                                    <label class="form-label">
                                        GRBS
                                    </label>

                                    <input id="GRBS"
                                           class="form-control">

                                </div>


                                <div class="col-md-2">

                                    <label class="form-label">
                                        Pain Score
                                    </label>

                                    <input id="PainScore"
                                           class="form-control">

                                </div>


                                <div class="col-md-2">

                                    <label class="form-label">
                                        GCS Score
                                    </label>

                                    <input id="GCSScore"
                                           class="form-control">

                                </div>


                                <div class="col-md-4">

                                    <label class="form-label">
                                        Pupils
                                    </label>

                                    <input id="Pupils"
                                           class="form-control">

                                </div>


                            </div>

                        </div>

                    </div>

                </div>



                <!-- EXAMINATION TAB -->

                <div class="tab-pane fade" id="exam">

                    <div class="card border-0 shadow-sm">

                        <div class="card-body">


                            <div class="row g-3">


                                <div class="col-md-6">

                                    <label>
                                        General Examination
                                    </label>

                                    <textarea id="GeneralExamination"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        CVS Examination
                                    </label>

                                    <textarea id="CVSExamination"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        RS Examination
                                    </label>

                                    <textarea id="RSExamination"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Abdomen Examination
                                    </label>

                                    <textarea id="AbdomenExamination"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        CNS Examination
                                    </label>

                                    <textarea id="CNSExamination"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Local Examination
                                    </label>

                                    <textarea id="LocalExamination"
                                              class="form-control"></textarea>

                                </div>


                            </div>


                        </div>

                    </div>

                </div>




                <!-- EMERGENCY TREATMENT TAB -->

                <div class="tab-pane fade" id="treatment">


                    <div class="card border-0 shadow-sm">

                        <div class="card-body">


                            <div class="row g-3">


                                <div class="col-md-6">

                                    <label>
                                        Provisional Diagnosis
                                    </label>

                                    <textarea id="ProvisionalDiagnosis"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Investigations Ordered
                                    </label>

                                    <textarea id="InvestigationsOrdered"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Investigation Results
                                    </label>

                                    <textarea id="InvestigationResults"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Procedures Performed
                                    </label>

                                    <textarea id="ProceduresPerformed"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Emergency Treatment
                                    </label>

                                    <textarea id="EmergencyTreatment"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Medications Administered
                                    </label>

                                    <textarea id="MedicationsAdministered"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-12">

                                    <label>
                                        IV Fluids
                                    </label>

                                    <textarea id="IVFluids"
                                              class="form-control"></textarea>

                                </div>


                            </div>


                        </div>


                    </div>


                </div>





                <!-- DISPOSITION TAB -->


                <div class="tab-pane fade" id="disposition">


                    <div class="card border-0 shadow-sm">


                        <div class="card-body">


                            <div class="row g-3">


                                <div class="col-md-6">

                                    <label>
                                        Final Diagnosis
                                    </label>

                                    <textarea id="FinalDiagnosis"
                                              class="form-control"></textarea>

                                </div>


                                <div class="col-md-6">

                                    <label>
                                        Disposition
                                    </label>


                                    <select id="Disposition"
                                            class="form-select">


                                        <option value="">
                                            Select
                                        </option>

                                        <option>
                                            Discharge
                                        </option>

                                        <option>
                                            Admission
                                        </option>

                                        <option>
                                            ICU
                                        </option>

                                        <option>
                                            Operation Theatre
                                        </option>

                                        <option>
                                            Referral
                                        </option>

                                        <option>
                                            Death
                                        </option>


                                    </select>


                                </div>



                                <div class="col-md-6">

                                    <label>
                                        Admitted Ward
                                    </label>

                                    <input id="AdmittedWard"
                                           class="form-control">

                                </div>



                                <div class="col-md-6">

                                    <label>
                                        Referred Hospital
                                    </label>

                                    <input id="ReferredHospital"
                                           class="form-control">

                                </div>



                                <div class="col-md-12">

                                    <label>
                                        Discharge Advice
                                    </label>

                                    <textarea id="DischargeAdvice"
                                              class="form-control"></textarea>

                                </div>



                                <div class="col-md-12">

                                    <label>
                                        Follow Up Advice
                                    </label>

                                    <textarea id="FollowUpAdvice"
                                              class="form-control"></textarea>

                                </div>


                            </div>


                        </div>


                    </div>


                </div>


            </div>

        </div>


    </div>



    <!-- SAVE BUTTON -->

    <div class="sticky-bar text-center">

        <button type="button"
                id="btnSave"
                class="btn btn-primary px-5 rounded-pill">

            💾 Save Emergency Case Sheet

        </button>


    </div>


</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>


<script>

    $(document).ready(function () 
    {

        console.log("EMR Case Sheet JS Loaded");

        function calculateBMI()
        {

            let weight = parseFloat($("#Weight").val());
            let height = parseFloat($("#Height").val());


            if(!weight || !height)
            {
                $("#BMI").val("");
                return;
            }


            let bmi = weight / ((height / 100) * (height / 100));


            $("#BMI").val(bmi.toFixed(2));

        }


        $("#Weight,#Height").on("input",calculateBMI);


        function getModel()
        {

            return {


                PatientId: '@vm.PatientId',

                DoctorId: '@vm.DoctorId',

                StudentId: '@vm.StudentId',

                AllotId: '@vm.AllotId',

                ReferredId: '@vm.ReferredId',

                OpNo: '@vm.OpNo',

                ArrivalMode:
                    $("#ArrivalMode").val(),

                ArrivalTime:
                    $("#ArrivalTime").val(),

                BroughtBy:
                    $("#BroughtBy").val(),

                TriageCategory:
                    $("#TriageCategory").val(),

                TriageTime:
                    $("#TriageTime").val(),

                TriageNotes:
                    $("#TriageNotes").val(),

                ChiefComplaint:
                    $("#ChiefComplaint").val(),

                HistoryOfPresentIllness:
                    $("#HistoryOfPresentIllness").val(),

                PastMedicalHistory:
                    $("#PastMedicalHistory").val(),

                PastSurgicalHistory:
                    $("#PastSurgicalHistory").val(),

                FamilyHistory:
                    $("#FamilyHistory").val(),

                PersonalHistory:
                    $("#PersonalHistory").val(),

                DrugHistory:
                    $("#DrugHistory").val(),

                AllergyHistory:
                    $("#AllergyHistory").val(),


                BloodPressure:
                    $("#BloodPressure").val(),


                PulseRate:
                    parseInt($("#PulseRate").val()) || null,


                Temperature:
                    parseFloat($("#Temperature").val()) || null,


                RespiratoryRate:
                    parseInt($("#RespiratoryRate").val()) || null,


                SpO2:
                    parseInt($("#SpO2").val()) || null,


                Weight:
                    parseFloat($("#Weight").val()) || null,


                Height:
                    parseFloat($("#Height").val()) || null,


                BMI:
                    parseFloat($("#BMI").val()) || null,


                GRBS:
                    parseFloat($("#GRBS").val()) || null,


                PainScore:
                    parseInt($("#PainScore").val()) || null,


                GCSScore:
                    parseInt($("#GCSScore").val()) || null,


                Pupils:
                    $("#Pupils").val(),

                GeneralExamination:
                    $("#GeneralExamination").val(),


                CVSExamination:
                    $("#CVSExamination").val(),


                RSExamination:
                    $("#RSExamination").val(),


                AbdomenExamination:
                    $("#AbdomenExamination").val(),


                CNSExamination:
                    $("#CNSExamination").val(),


                LocalExamination:
                    $("#LocalExamination").val(),

                ProvisionalDiagnosis:
                    $("#ProvisionalDiagnosis").val(),


                InvestigationsOrdered:
                    $("#InvestigationsOrdered").val(),


                InvestigationResults:
                    $("#InvestigationResults").val(),


                ProceduresPerformed:
                    $("#ProceduresPerformed").val(),


                EmergencyTreatment:
                    $("#EmergencyTreatment").val(),


                MedicationsAdministered:
                    $("#MedicationsAdministered").val(),


                IVFluids:
                    $("#IVFluids").val(),


                FinalDiagnosis:
                    $("#FinalDiagnosis").val(),


                Disposition:
                    $("#Disposition").val(),


                AdmittedWard:
                    $("#AdmittedWard").val(),


                ReferredHospital:
                    $("#ReferredHospital").val(),


                DischargeAdvice:
                    $("#DischargeAdvice").val(),


                FollowUpAdvice:
                    $("#FollowUpAdvice").val()

            };


        }

        function validate(model)
        {

            let errors=[];


            if(!model.ChiefComplaint)
                errors.push("Chief Complaint is required");



            if(model.Temperature)
            {

                if(model.Temperature < 30 ||
                   model.Temperature > 45)
                {
                    errors.push(
                    "Temperature should be between 30°C - 45°C"
                    );
                }

            }


            if(model.SpO2)
            {

                if(model.SpO2 < 50 ||
                   model.SpO2 > 100)
                {
                    errors.push(
                    "SpO₂ should be between 50 - 100"
                    );
                }

            }

            if(model.PulseRate)
            {

                if(model.PulseRate > 220)
                {
                    errors.push(
                    "Invalid Pulse Rate"
                    );
                }

            }


            if(model.GCSScore)
            {

                if(model.GCSScore < 3 ||
                   model.GCSScore > 15)
                {
                    errors.push(
                    "GCS Score should be between 3 - 15"
                    );
                }

            }



            if(model.PainScore)
            {

                if(model.PainScore < 0 ||
                   model.PainScore > 10)
                {
                    errors.push(
                    "Pain Score should be between 0 - 10"
                    );
                }

            }

            return errors;

        }


        $("#btnSave").click(function(){

            let model = getModel();

            let errors = validate(model);
            if(errors.length > 0)
            {

                errors.forEach(function(e){

                    toastr.error(
                        e,
                        "Validation Error"
                    );

                });


                return;

            }


            $.ajax({

                url: '/Emergency/SaveCaseSheet',

                type:
                'POST',

                contentType:
                'application/json',

                data:
                JSON.stringify(model),


                beforeSend:function(){
                   $("#btnSave")
                    .prop("disabled",true)
                    .text("Saving...");

                },
                success:function(res){
                    toastr.success(
                        "Emergency Case Sheet Saved Successfully"
                    );
                    setTimeout(function(){
                        window.location.href =
                        '/Emergency/PatientSearch';

                    },1000);

                },

                error:function(xhr){
                    console.log(xhr.responseText);
                    toastr.error(
                        "Save Failed"
                    );
                },

                complete:function(){
                    $("#btnSave")
                    .prop("disabled",false)
                    .text("💾 Save Emergency Case Sheet");

                }
            });

        });

    });
</script>