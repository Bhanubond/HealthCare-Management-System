@model HMS.Models.CourseYearDto

@{
    ViewData["Title"] = "Course Year Details";
}

<div class="container mt-4">

    <div class="card">

        <div class="card-header bg-info text-white">

            Course Year Details

        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-3">
                    Course
                </dt>

                <dd class="col-sm-9">
                    @Model.CourseName
                </dd>

                <dt class="col-sm-3">
                    Year
                </dt>

                <dd class="col-sm-9">
                    @Model.YearName
                </dd>

                <dt class="col-sm-3">
                    Status
                </dt>

                <dd class="col-sm-9">
                    @(Model.IsActive ? "Active" : "Inactive")
                </dd>

            </dl>

        </div>

        <div class="card-footer">

            <a asp-action="Index"
               class="btn btn-secondary">

                Back

            </a>

        </div>

    </div>

</div>