@model HMS.Models.CourseYearDto

@{
    ViewData["Title"] = "Delete Course Year";
}

<div class="container mt-4">

    <div class="card border-danger">

        <div class="card-header bg-danger text-white">

            Delete Course Year

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                Are you sure you want to delete this record?

            </div>

            <dl class="row">

                <dt class="col-sm-3">
                    Course
                </dt>

                <dd class="col-sm-9">
                    @Model.CourseName
                </dd>

                <dt class="col-sm-3">
                    Year
                </dt>

                <dd class="col-sm-9">
                    @Model.YearName
                </dd>

                <dt class="col-sm-3">
                    Status
                </dt>

                <dd class="col-sm-9">
                    @(Model.IsActive ? "Active" : "Inactive")
                </dd>

            </dl>

            <form asp-action="Delete">

                <input asp-for="CourseYearId" type="hidden" />

                <button class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>