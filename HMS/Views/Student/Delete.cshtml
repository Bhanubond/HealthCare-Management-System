@model HMS.Entities.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="card shadow p-4 border-danger">

    <h3 class="text-danger mb-3">Delete Student</h3>

    <h5>Are you sure you want to delete this record?</h5>

    <hr />

    <table class="table table-bordered">

        <tr>
            <th>Student Code</th>
            <td>@Model.StudentCode</td>
        </tr>

        <tr>
            <th>Name</th>
            <td>@Model.StudentName</td>
        </tr>

        <tr>
            <th>Gender</th>
            <td>@Model.Gender</td>
        </tr>

        <tr>
            <th>Phone</th>
            <td>@Model.Phone</td>
        </tr>

        <tr>
            <th>Email</th>
            <td>@Model.Email</td>
        </tr>

        <tr>
            <th>Address</th>
            <td>@Model.Address</td>
        </tr>

        <tr>
            <th>Admission Date</th>
            <td>@Model.AdmissionDate.ToString("yyyy-MM-dd")</td>
        </tr>

        <tr>
            <th>Status</th>
            <td>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactive</span>
                }
            </td>
        </tr>

    </table>

    <form asp-action="Delete" method="post">

        <input type="hidden" asp-for="StudentId" />

        <button type="submit" class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>