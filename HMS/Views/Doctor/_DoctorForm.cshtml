@model HMS.Models.DoctorFormViewModel

<input type="hidden" asp-for="Doctor.DoctorId" />

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="Doctor.DoctorCode" class="form-label fw-bold"></label>
        <input asp-for="Doctor.DoctorCode" class="form-control" />
        <span asp-validation-for="Doctor.DoctorCode" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.DoctorName" class="form-label fw-bold"></label>
        <input asp-for="Doctor.DoctorName" class="form-control" />
        <span asp-validation-for="Doctor.DoctorName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.Gender" class="form-label fw-bold"></label>
        <select asp-for="Doctor.Gender" class="form-select">
            <option value="">-- Select Gender --</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
        </select>
        <span asp-validation-for="Doctor.Gender" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.DOB" class="form-label fw-bold">Date of Birth</label>
        <input asp-for="Doctor.DOB" type="date" class="form-control" />
        <span asp-validation-for="Doctor.DOB" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.Phone" class="form-label fw-bold"></label>
        <input asp-for="Doctor.Phone" class="form-control" />
        <span asp-validation-for="Doctor.Phone" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.Email" class="form-label fw-bold"></label>
        <input asp-for="Doctor.Email" class="form-control" />
        <span asp-validation-for="Doctor.Email" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.DepartmentId" class="form-label fw-bold">Department</label>
        <select asp-for="Doctor.DepartmentId"
                class="form-select"
                asp-items="@(new SelectList(Model.Departments, "DeptId", "DeptName"))">
            <option value="">-- Select Department --</option>
        </select>
        <span asp-validation-for="Doctor.DepartmentId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.DesignationId" class="form-label fw-bold">Designation</label>
        <select asp-for="Doctor.DesignationId"
                class="form-select"
                asp-items="@(new SelectList(Model.Designations, "DesignationId", "DesignationName"))">
            <option value="">-- Select Designation --</option>
        </select>
        <span asp-validation-for="Doctor.DesignationId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.CountryId" class="form-label fw-bold">Country</label>
        <select id="countryId"
                asp-for="Doctor.CountryId"
                class="form-select"
                asp-items="@(new SelectList(Model.Countries, "CountryId", "CountryName"))">
            <option value="">-- Select Country --</option>
        </select>
        <span asp-validation-for="Doctor.CountryId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.StateId" class="form-label fw-bold">State</label>
        <select id="stateId" asp-for="Doctor.StateId" class="form-select">
            <option value="">-- Select State --</option>
        </select>
        <span asp-validation-for="Doctor.StateId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.MandalId" class="form-label fw-bold">Mandal</label>
        <select id="mandalId" asp-for="Doctor.MandalId" class="form-select">
            <option value="">-- Select Mandal --</option>
        </select>
        <span asp-validation-for="Doctor.MandalId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.CityId" class="form-label fw-bold">City</label>
        <select id="cityId" asp-for="Doctor.CityId" class="form-select">
            <option value="">-- Select City --</option>
        </select>
        <span asp-validation-for="Doctor.CityId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Doctor.JoiningDate" class="form-label fw-bold"></label>
        <input asp-for="Doctor.JoiningDate" type="date" class="form-control" />
        <span asp-validation-for="Doctor.JoiningDate" class="text-danger"></span>
    </div>

    <div class="col-md-4 d-flex align-items-center">
        <div class="form-check mt-4">
            <input asp-for="Doctor.IsActive" class="form-check-input" />
            <label asp-for="Doctor.IsActive" class="form-check-label fw-bold"></label>
        </div>
    </div>
</div>
